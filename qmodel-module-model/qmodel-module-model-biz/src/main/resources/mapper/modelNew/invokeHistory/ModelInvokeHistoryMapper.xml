            <if test="modelName != null">model_name = #{modelName},</if>
            <if test="resourceId != null">resource_id = #{resourceId},</if>
            <if test="versionId != null">version_id = #{versionId},</if>
            <if test="requestMethod != null">request_method = #{requestMethod},</if>
            <if test="invokeType != null">invoke_type = #{invokeType},</if>
            <if test="inputParams != null">input_params = #{inputParams},</if>
            <if test="outputResult != null">output_result = #{outputResult},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
