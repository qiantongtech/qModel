    <sql id="selectModelInvokeHistoryVo">
        select id, model_id, model_name, resource_id, version_id, request_method, invoke_type, input_params, output_result, start_time, end_time, duration, error_message, status, client_ip, valid_flag, del_flag, create_by, creator_id, create_time, update_by, updator_id, update_time, remark from model_invoke_history
    </sql>

    <select id="selectModelInvokeHistoryList" parameterType="ModelInvokeHistoryDO" resultMap="ModelInvokeHistoryResult">
        <include refid="selectModelInvokeHistoryVo"/>
        <where>
            <if test="modelId != null "> and model_id = #{modelId}</if>
            <if test="modelName != null  and modelName != ''"> and model_name like concat('%', #{modelName}, '%')</if>
            <if test="resourceId != null "> and resource_id = #{resourceId}</if>
            <if test="versionId != null "> and version_id = #{versionId}</if>
            <if test="requestMethod != null  and requestMethod != ''"> and request_method = #{requestMethod}</if>
            <if test="invokeType != null  and invokeType != ''"> and invoke_type = #{invokeType}</if>
            <if test="inputParams != null  and inputParams != ''"> and input_params = #{inputParams}</if>
            <if test="outputResult != null  and outputResult != ''"> and output_result = #{outputResult}</if>
            <if test="startTime != null "> and start_time = #{startTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
            <if test="duration != null "> and duration = #{duration}</if>
            <if test="errorMessage != null  and errorMessage != ''"> and error_message = #{errorMessage}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="clientIp != null  and clientIp != ''"> and client_ip = #{clientIp}</if>
            <if test="createTime != null "> and create_time = #{createTime}</if>
        </where>
    </select>

    <select id="selectModelInvokeHistoryById" parameterType="Long" resultMap="ModelInvokeHistoryResult">
