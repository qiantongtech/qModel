<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tech.qiantong.qmodel.module.modelReconstitution.mapper.ModelInterfaceAddressMapper">

    <resultMap type="ModelInterfaceAddress" id="ModelInterfaceAddressResult">
        <result property="id"    column="ID"    />
        <result property="companyId"    column="COMPANY_ID"    />
        <result property="modelId"    column="MODEL_ID"    />
        <result property="interfaceAddress"    column="INTERFACE_ADDRESS"    />
        <result property="versionId"    column="VERSION_ID"    />
        <result property="requestMethod"    column="REQUEST_METHOD"    />
        <result property="inputParameter"    column="INPUT_PARAMETER"    />
        <result property="outputParameter"    column="OUTPUT_PARAMETER"    />
        <result property="inputParameterIllustrate"    column="INPUT_PARAMETER_ILLUSTRATE"    />
        <result property="outputParameterIllustrate"    column="OUTPUT_PARAMETER_ILLUSTRATE"    />
        <result property="delFlag"    column="DEL_FLAG"    />
        <result property="createBy"    column="CREATE_BY"    />
        <result property="creatorId"    column="CREATOR_ID"    />
        <result property="createTime"    column="CREATE_TIME"    />
        <result property="updateBy"    column="UPDATE_BY"    />
        <result property="updatorId"    column="UPDATOR_ID"    />
        <result property="updateTime"    column="UPDATE_TIME"    />
        <result property="remark"    column="REMARK"    />
    </resultMap>

    <sql id="selectModelInterfaceAddressVo">
        select ID, COMPANY_ID, MODEL_ID, INTERFACE_ADDRESS, VERSION_ID, REQUEST_METHOD, INPUT_PARAMETER, OUTPUT_PARAMETER,INPUT_PARAMETER_ILLUSTRATE,OUTPUT_PARAMETER_ILLUSTRATE, DEL_FLAG, CREATE_BY, CREATOR_ID, CREATE_TIME, UPDATE_BY, UPDATOR_ID, UPDATE_TIME, REMARK from MODEL_INTERFACE_ADDRESS
    </sql>

    <select id="selectModelInterfaceAddressList" parameterType="ModelInterfaceAddress" resultMap="ModelInterfaceAddressResult">
        <include refid="selectModelInterfaceAddressVo"/>
        <where>
            <if test="companyId != null "> and COMPANY_ID = #{companyId}</if>
            <if test="modelId != null "> and MODEL_ID = #{modelId}</if>
            <if test="interfaceAddress != null  and interfaceAddress != ''"> and INTERFACE_ADDRESS = #{interfaceAddress}</if>
            <if test="versionId != null "> and VERSION_ID = #{versionId}</if>
            <if test="requestMethod != null "> and REQUEST_METHOD = #{requestMethod}</if>
            <if test="inputParameter != null  and inputParameter != ''"> and INPUT_PARAMETER = #{inputParameter}</if>
            <if test="outputParameter != null  and outputParameter != ''"> and OUTPUT_PARAMETER = #{outputParameter}</if>
            <if test="inputParameterIllustrate != null  and inputParameterIllustrate != ''"> and INPUT_PARAMETER_ILLUSTRATE = #{inputParameterIllustrate}</if>
            <if test="outputParameterIllustrate != null  and outputParameterIllustrate != ''"> and OUTPUT_PARAMETER_ILLUSTRATE = #{outputParameterIllustrate}</if>
            <if test="creatorId != null "> and CREATOR_ID = #{creatorId}</if>
            <if test="updatorId != null "> and UPDATOR_ID = #{updatorId}</if>
            <if test="delFlag != null "> and DEL_FLAG = #{delFlag}</if>
        </where>
    </select>

    <select id="selectModelInterfaceAddressById" parameterType="Long" resultMap="ModelInterfaceAddressResult">
        <include refid="selectModelInterfaceAddressVo"/>
        where ID = #{id}
    </select>

    <insert id="insertModelInterfaceAddress" parameterType="ModelInterfaceAddress">
        insert into MODEL_INTERFACE_ADDRESS
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">ID,</if>
            <if test="companyId != null">COMPANY_ID,</if>
            <if test="modelId != null">MODEL_ID,</if>
            <if test="interfaceAddress != null">INTERFACE_ADDRESS,</if>
            <if test="versionId != null">VERSION_ID,</if>
            <if test="requestMethod != null">REQUEST_METHOD,</if>
            <if test="inputParameter != null">INPUT_PARAMETER,</if>
            <if test="outputParameter != null">OUTPUT_PARAMETER,</if>
            <if test="inputParameterIllustrate != null">INPUT_PARAMETER_ILLUSTRATE,</if>
            <if test="outputParameterIllustrate != null">OUTPUT_PARAMETER_ILLUSTRATE,</if>
            <if test="delFlag != null">DEL_FLAG,</if>
            <if test="createBy != null">CREATE_BY,</if>
            <if test="creatorId != null">CREATOR_ID,</if>
            <if test="createTime != null">CREATE_TIME,</if>
            <if test="updateBy != null">UPDATE_BY,</if>
            <if test="updatorId != null">UPDATOR_ID,</if>
            <if test="updateTime != null">UPDATE_TIME,</if>
            <if test="remark != null">REMARK,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="companyId != null">#{companyId},</if>
            <if test="modelId != null">#{modelId},</if>
            <if test="interfaceAddress != null">#{interfaceAddress},</if>
            <if test="versionId != null">#{versionId},</if>
            <if test="requestMethod != null">#{requestMethod},</if>
            <if test="inputParameter != null">#{inputParameter},</if>
            <if test="outputParameter != null">#{outputParameter},</if>
            <if test="inputParameterIllustrate != null">#{inputParameterIllustrate},</if>
            <if test="outputParameterIllustrate != null">#{outputParameterIllustrate},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updatorId != null">#{updatorId},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateModelInterfaceAddress" parameterType="ModelInterfaceAddress">
        update MODEL_INTERFACE_ADDRESS
        <trim prefix="SET" suffixOverrides=",">
            <if test="companyId != null">COMPANY_ID = #{companyId},</if>
            <if test="modelId != null">MODEL_ID = #{modelId},</if>
            <if test="interfaceAddress != null">INTERFACE_ADDRESS = #{interfaceAddress},</if>
            <if test="versionId != null">VERSION_ID = #{versionId},</if>
            <if test="requestMethod != null">REQUEST_METHOD = #{requestMethod},</if>
            <if test="inputParameter != null">INPUT_PARAMETER = #{inputParameter},</if>
            <if test="outputParameter != null">OUTPUT_PARAMETER = #{outputParameter},</if>
            <if test="inputParameterIllustrate != null">INPUT_PARAMETER_ILLUSTRATE = #{inputParameterIllustrate},</if>
            <if test="outputParameterIllustrate != null">OUTPUT_PARAMETER_ILLUSTRATE = #{outputParameterIllustrate},</if>
            <if test="delFlag != null">DEL_FLAG = #{delFlag},</if>
            <if test="createBy != null">CREATE_BY = #{createBy},</if>
            <if test="creatorId != null">CREATOR_ID = #{creatorId},</if>
            <if test="createTime != null">CREATE_TIME = #{createTime},</if>
            <if test="updateBy != null">UPDATE_BY = #{updateBy},</if>
            <if test="updatorId != null">UPDATOR_ID = #{updatorId},</if>
            <if test="updateTime != null">UPDATE_TIME = #{updateTime},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </trim>
        where ID = #{id}
    </update>

    <update id="deleteModelInterfaceAddressById" parameterType="Long">
        update MODEL_INTERFACE_ADDRESS set del_flag = 1 where ID = #{id}
    </update>

    <update id="deleteModelInterfaceAddressByIds" parameterType="String">
        update MODEL_INTERFACE_ADDRESS set del_flag = 1 where ID in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>
</mapper>
